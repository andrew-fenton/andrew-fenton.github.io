---
import AsciiAnimation from '@/components/AsciiAnimation.astro'
import BaseHead from '@/components/BaseHead.astro'
---

<html lang='en-CA'>
	<head>
		<BaseHead title='Home' description='Andrew Fenton' />
		<link rel='preconnect' href='https://fonts.googleapis.com' />
		<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
		<link
			href='https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Inter:wght@300;400;500&display=swap'
			rel='stylesheet'
		/>
		<style>
			@keyframes content-enter {
				from {
					opacity: 0;
					transform: translateY(10px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@keyframes koi-fade {
				from {
					opacity: 0;
				}
				to {
					opacity: 0.35;
				}
			}

			@keyframes koi-drift {
				0%,
				100% {
					transform: translateY(-4px);
				}
				50% {
					transform: translateY(4px);
				}
			}

			.enter {
				animation: content-enter 0.5s ease-out forwards;
				opacity: 0;
				transform: translateY(10px);
			}

			.koi-backdrop {
				animation: koi-fade 1.2s ease-out 350ms forwards;
				opacity: 0;
				pointer-events: none;
			}

			.koi-drift {
				animation: koi-drift 10s ease-in-out infinite;
				max-width: 100%;
			}

			.social-link {
				color: #888;
				cursor: pointer;
				opacity: 0.55;
				transition:
					color 200ms ease,
					opacity 200ms ease;
			}

			.social-link:hover,
			.social-link:focus-visible {
				color: #111;
				opacity: 1;
			}

			.detail-text,
			.bio-text {
				font-family:
					'DM Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
					monospace;
			}

			.external-arrow {
				display: inline-block;
				font-size: 1.1em;
				line-height: 1;
				margin-inline-start: 0.18rem;
				opacity: 0.72;
				transform: translateY(-0.12em);
			}

			.hero-grid {
				display: grid;
				grid-template-columns: minmax(0, 420px);
				gap: clamp(2rem, 6vw, 4rem);
				align-items: center;
				isolation: isolate;
				margin-inline: auto;
				max-width: min(100%, 50rem);
				position: relative;
				width: 100%;
			}

			.hero-copy {
				min-width: 0;
				position: relative;
				z-index: 2;
			}

			.koi-backdrop {
				inset-block-start: calc(50% + clamp(2rem, 6vh, 2rem));
				inset-inline-start: clamp(13rem, 30vw, 17rem);
				min-width: 0;
				position: absolute;
				transform: translateY(-50%);
				width: max-content;
				z-index: 1;
			}

			@media (max-width: 767px) {
				.hero-grid {
					grid-template-columns: minmax(0, 1fr);
					gap: 3rem;
				}

				.koi-backdrop {
					inset-block-start: calc(100% + 1.5rem);
					inset-inline-start: 50%;
					transform: translate(-50%, 0);
					width: max-content;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.enter,
				.koi-backdrop,
				.koi-drift {
					animation: none;
					opacity: 1;
					transform: none;
				}

				.koi-backdrop {
					opacity: 0.3;
				}
			}
		</style>
	</head>
	<body class='overflow-x-hidden bg-[#fafafa] text-[#111]'>
		<main
			class='relative z-10 mx-auto flex min-h-screen w-full max-w-6xl items-center px-6 pb-20 [font-family:Inter,sans-serif] sm:px-8'
		>
			<section class='hero-grid'>
				<div class='hero-copy'>
					<h1
						class='enter font-regular text-[44px] leading-none tracking-[-0.02em] text-[#111] sm:text-[56px]'
						style='animation-delay: 0ms'
					>
						Andrew Fenton
					</h1>
					<p
						class='detail-text enter mt-5 text-xs font-medium uppercase tracking-[0.12em] text-[#999]'
						style='animation-delay: 80ms'
					>
						Software Engineer
					</p>
					<p
						class='bio-text enter mt-6 max-w-[300px] text-[15px] font-normal leading-[1.6] text-[#444] sm:text-[17px]'
						style='animation-delay: 160ms'
					>
						SWE at AWS Rendering
					</p>
					<nav
						aria-label='Links'
						class='enter mt-8 flex items-center gap-5 text-sm font-normal'
						style='animation-delay: 240ms'
					>
						<a
							class='detail-text social-link'
							href='https://github.com/andrew-fenton'
							rel='noreferrer'
							target='_blank'
						>
							GitHub<span class='external-arrow' aria-hidden='true'>↗</span>
						</a>
						<a
							class='detail-text social-link'
							href='https://www.linkedin.com/in/andrewfenton898/'
							rel='noreferrer'
							target='_blank'
						>
							LinkedIn<span class='external-arrow' aria-hidden='true'>↗</span>
						</a>
					</nav>
				</div>
				<div
					class='koi-backdrop flex h-[18rem] items-center justify-center opacity-0 md:h-[18rem]'
					aria-hidden='true'
				>
					<div class='koi-drift'>
						<AsciiAnimation
							clip={false}
							fps={60}
							fontSize='clamp(5px,0.62vw,8px)'
							src='/animations/koi_v3.frames.txt'
							tone='koi'
							className='shrink-0'
						/>
					</div>
				</div>
			</section>
		</main>

		<footer
			class='fixed inset-x-0 bottom-0 z-50 flex h-14 items-center justify-center px-6 text-center text-xs font-normal leading-none text-[#999] [font-family:Inter,sans-serif]'
		>
			<span>Vancouver, BC · PT <time id='pacific-time'>--:--</time></span>
		</footer>

		<script>
			const timeElement = document.getElementById('pacific-time')

			const formatter = new Intl.DateTimeFormat('en-CA', {
				hour: 'numeric',
				minute: '2-digit',
				timeZone: 'America/Vancouver'
			})

			function updatePacificTime() {
				if (timeElement) {
					timeElement.textContent = formatter.format(new Date())
				}
			}

			updatePacificTime()
			window.setInterval(updatePacificTime, 1000)
		</script>
	</body>
</html>
