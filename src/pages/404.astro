---
import BaseHead from '@/components/BaseHead.astro'
---

<html lang='en-CA'>
	<head>
		<BaseHead title='404' description='Page not found.' />
		<link rel='preconnect' href='https://fonts.googleapis.com' />
		<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
		<link
			href='https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Inter:wght@300;400;500&display=swap'
			rel='stylesheet'
		/>
		<style>
			@keyframes content-enter {
				from {
					opacity: 0;
					transform: translateY(10px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			.enter {
				animation: content-enter 0.5s ease-out forwards;
				opacity: 0;
				transform: translateY(10px);
			}

			.detail-text {
				font-family:
					'DM Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
					monospace;
			}

			.home-link {
				color: #888;
				cursor: pointer;
				opacity: 0.6;
				transition:
					color 200ms ease,
					opacity 200ms ease;
			}

			.home-link:hover,
			.home-link:focus-visible {
				color: #111;
				opacity: 1;
			}

			.external-arrow {
				display: inline-block;
				font-size: 1.1em;
				line-height: 1;
				margin-inline-start: 0.18rem;
				opacity: 0.72;
				transform: translateY(-0.12em);
			}

			@media (prefers-reduced-motion: reduce) {
				.enter {
					animation: none;
					opacity: 1;
					transform: none;
				}
			}
		</style>
	</head>
	<body class='overflow-x-hidden bg-[#fafafa] text-[#111]'>
		<main
			class='relative z-10 mx-auto flex min-h-screen w-full max-w-6xl items-center px-6 pb-20 [font-family:Inter,sans-serif] sm:px-8'
		>
			<section class='w-full max-w-[420px]'>
				<p
					class='detail-text enter text-xs font-medium uppercase tracking-[0.12em] text-[#999]'
					style='animation-delay: 0ms'
				>
					404
				</p>
				<h1
					class='enter mt-5 text-[44px] font-normal leading-none tracking-[-0.02em] text-[#111] sm:text-[56px]'
					style='animation-delay: 80ms'
				>
					Page not found
				</h1>
				<p
					class='detail-text enter mt-6 max-w-[320px] text-[15px] font-normal leading-[1.6] text-[#444] sm:text-[17px]'
					style='animation-delay: 160ms'
				>
					This page does not exist or has moved.
				</p>
				<nav
					aria-label='Not found navigation'
					class='enter mt-8 flex items-center gap-5 text-sm font-normal'
					style='animation-delay: 240ms'
				>
					<a class='detail-text home-link' href='/'> Home </a>
				</nav>
			</section>
		</main>

		<footer
			class='fixed inset-x-0 bottom-0 z-50 flex h-14 items-center justify-center px-6 text-center text-xs font-normal leading-none text-[#999] [font-family:Inter,sans-serif]'
		>
			<span>Vancouver, BC · PT <time id='pacific-time'>--:--</time></span>
		</footer>

		<script>
			const timeElement = document.getElementById('pacific-time')

			const formatter = new Intl.DateTimeFormat('en-CA', {
				hour: 'numeric',
				minute: '2-digit',
				timeZone: 'America/Vancouver'
			})

			function updatePacificTime() {
				if (timeElement) {
					timeElement.textContent = formatter.format(new Date())
				}
			}

			updatePacificTime()
			window.setInterval(updatePacificTime, 1000)
		</script>
	</body>
</html>
